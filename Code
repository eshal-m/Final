    gr.Markdown(
        """
        # Applicant Ranking Simulator
        Enter applicants one per line using this format:
        `name, gpa, volunteer_hours, essay_score`
        The app computes a final score, sorts applicants with a manual insertion sort, and shows the ranking process step by step.
        """
    )

    with gr.Row():
        input_box = gr.Textbox(
            label="Applicants",
            lines=10,
            value=SAMPLE_INPUT,
            placeholder="Name, GPA, volunteer_hours, essay_score",
        )
        top_n_box = gr.Number(label="Top N to display", value=3, precision=0)

    run_button = gr.Button("Rank Applicants")

    summary_box = gr.Markdown(label="Scoring and validation notes")
    top_table = gr.Dataframe(
        headers=["Rank", "Name", "Final Score"],
        datatype=["number", "str", "number"],
        label="Top N Applicants",
        interactive=False,
        wrap=True,
    )
    full_table = gr.Dataframe(
        headers=["Rank", "Name", "GPA", "Volunteer Hours", "Essay Score", "Final Score"],
        datatype=["number", "str", "number", "number", "number", "number"],
        label="Full Ranking",
        interactive=False,
        wrap=True,
    )
    steps_box = gr.Textbox(label="Sorting steps", lines=18, interactive=False)

    run_button.click(
        fn=process_applicants,
        inputs=[input_box, top_n_box],
        outputs=[summary_box, top_table, full_table, steps_box],
    )

if __name__ == "__main__":
    demo.launch()
